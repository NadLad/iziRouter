# RouterCrabs — Complexity Scoring Keywords
# ─────────────────────────────────────────────
# This file is DEDICATED to keyword-based complexity scoring.
# Three categories, balanced across French, English, and Arabic.
# Modify freely — changes take effect on next restart.
# ─────────────────────────────────────────────

# Markers indicating source code in the prompt
code_markers:
  - "```"
  - "fn "
  - "pub fn"
  - "async fn"
  - "def "
  - "class "
  - "import "
  - "package "
  - "#include"
  - "impl "
  - "struct "
  - "enum "
  - "trait "
  - "let mut"
  - "const "
  - "var "
  - "function"
  - "export"
  - "require"
  - "SELECT "
  - "INSERT "
  - "UPDATE "
  - "DELETE "

