# iziRouter — Variables d'environnement

# Clé API DeepSeek (obligatoire)
DEEPSEEK_API_KEY=sk-votre-cle-api

# Modèles (optionnel — valeurs par défaut ci-dessous)
FLASH_MODEL=deepseek-v4-flash
PRO_MODEL=deepseek-v4-pro

# Base URL de l'API DeepSeek (optionnel)
DEEPSEEK_API_BASE=https://api.deepseek.com

# Port d'écoute (optionnel, défaut: 8001)
PORT=8001

# Niveau de log (optionnel, défaut: info,izi_router=debug)
RUST_LOG=info,izi_router=debug
